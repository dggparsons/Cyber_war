# Caddyfile - Automatic HTTPS with Let's Encrypt

un.blorebank.net {
    # Backend API routes
    handle /api/* {
        reverse_proxy backend:5050
    }

    # Socket.IO WebSocket routes
    handle /socket.io/* {
        reverse_proxy backend:5050
    }

    # Frontend (React SPA)
    handle /* {
        reverse_proxy frontend:80
    }
}

# Redirect HTTP to HTTPS (automatic)